{
    "deployment": {
        "github": {
            "owner": "vertb1",
            "repo": "Cascade"
        }
    },
    
    "buildConfigs": [
        {
            "name": "Tests",
            "inputDir": "tests",
            "outputDir": "generated/tests",
            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/darklua/unminified.json"
        },

        {
            "name": "Debug",

            "promptVersion": false,
            "promptDeploy": false,

            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/darklua/unminified.json",
            "input": "src/init.luau",
            "output": "generated/debug/dist.luau"
        },

        {
            "name": "Beta",

            "promptVersion": true,
            "promptDeploy": true,
            "prerelease": true,

            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/darklua/stable.json",
            "input": "src/init.luau",
            "output": "generated/beta/dist.luau",
            "variants": [
                {
                    "name": "Typed",
                    "darkluaConfig": "pipeline/darklua/typed.json",
                    "output": "generated/beta/dist-typed.luau"
                },
                {
                    "name": "Unminified",
                    "darkluaConfig": "pipeline/darklua/unminified.json",
                    "output": "generated/beta/dist-unminified.luau"
                }
            ]
        },

        {
            "name": "Release",
            
            "promptVersion": true,
            "promptDeploy": true,

            "frame": "pipeline/frames/stable.luau",
            "darkluaConfig": "pipeline/darklua/stable.json",
            "input": "src/init.luau",
            "output": "generated/release/dist.luau",
            "variants": [
                {
                    "name": "Typed",
                    "darkluaConfig": "pipeline/darklua/typed.json",
                    "output": "generated/beta/dist-typed.luau"
                },
                {
                    "name": "Unminified",
                    "darkluaConfig": "pipeline/darklua/unminified.json",
                    "output": "generated/release/dist-unminified.luau"
                }
            ]
        }
  ]
}